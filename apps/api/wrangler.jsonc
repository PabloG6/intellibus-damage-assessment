{
	"name": "yardwatch-api",
	"main": "src/index.ts",
	"compatibility_flags": ["nodejs_compat"],
	"compatibility_date": "2026-03-15",
	"hyperdrive": [
		{
			"binding": "HYPERDRIVE",
			"id": "b08ac5c1673f4919bc6154717ae8ace3",
			"localConnectionString": "postgresql://yardwatch:yardwatch123@localhost:5432/yardwatch"
		}
	],
	"placement": {
		"region": "aws:us-east-1"
	},
	"vars": {
		"CORS_ALLOWED_ORIGINS": "http://localhost:3000,http://localhost:3001",
		"PARTYKIT_URL": "http://127.0.0.1:1999",
		"PARTYKIT_SERVICE_SECRET": "yardwatch-local-service-secret",
		"REALTIME_TOKEN_SECRET": "yardwatch-local-realtime-secret"
	},
	"observability": {
		"enabled": true,
	},
}
