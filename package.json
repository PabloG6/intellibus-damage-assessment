{
  "name": "yardwatch",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "auth:schema:generate": "npm run auth:schema:generate --workspace @workspace/auth",
    "db:push:production": "bash ./scripts/push-postgres-to-production.sh",
    "db:reconcile-auth": "npm run auth:reconcile --workspace @workspace/db",
    "dev": "concurrently -n web,reporter,api,auth,realtime -c blue,cyan,green,magenta,yellow \"npm run dev --workspace web\" \"npm run dev --workspace reporter\" \"npm run dev --workspace @workspace/api\" \"npm run dev --workspace auth\" \"npm run dev --workspace realtime\"",
    "drizzle-kit:generate": "npm run drizzle:generate --workspace @workspace/db",
    "drizzle-kit:migrate": "npm run drizzle:migrate --workspace @workspace/db",
    "lint": "npm run lint --workspaces --if-present",
    "format": "npm run format --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "dependencies": {
    "@better-auth/api-key": "1.5.5",
    "@better-auth/core": "1.5.5",
    "@better-auth/drizzle-adapter": "1.5.5",
    "@better-auth/utils": "0.3.1",
    "better-auth": "1.5.5"
  },
  "devDependencies": {
    "@better-auth/cli": "1.4.21",
    "concurrently": "^9.2.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.8",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "npm@10.9.2"
}
